# Day-1 Framework Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# TESTING MODE
# =============================================================================
# Set the testing environment: mock, local, integration, staging, production
TESTING_MODE=mock

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# KAFKA CONFIGURATION
# =============================================================================
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_USERNAME=
KAFKA_PASSWORD=

# =============================================================================
# MONGODB CONFIGURATION
# =============================================================================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=your_secure_password_here
MONGO_DATABASE=netskope_local

# =============================================================================
# NETSKOPE API CONFIGURATION
# =============================================================================
NETSKOPE_API_HOST=localhost
NETSKOPE_API_PORT=8080
NETSKOPE_API_KEY=your_api_key_here
NETSKOPE_TENANT_URL=https://your-tenant.goskope.com

# =============================================================================
# AWS CONFIGURATION (for LocalStack or real AWS)
# =============================================================================
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=netskope_grafana_2024

# =============================================================================
# KUBERNETES CONFIGURATION (for integration/staging/production)
# =============================================================================
KUBECONFIG=/path/to/kubeconfig
K8S_NAMESPACE=netskope

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
JAEGER_URL=http://localhost:16686

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Set to true to enable strict SSL/TLS validation
STRICT_SSL=false

# =============================================================================
# CI/CD SETTINGS
# =============================================================================
CI=false
GITHUB_TOKEN=
